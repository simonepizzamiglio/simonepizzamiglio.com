---
import { Github, Globe } from "@lucide/astro"

interface Props {
	project: {
		name: string
		description: string
		technologies: string[]
		githubUrl: string
		websiteUrl?: string
	}
}

const { project } = Astro.props
---

<div class="bg-base-300/60 border border-base-100 rounded-3xl p-8">
	<h2 class="text-xl font-bold mb-4 text-base-content">{project.name}</h2>
	<p class="text-sm mb-6 leading-relaxed text-base-content/80">
		{project.description}
	</p>
	<div class="mb-8 flex flex-wrap gap-2">
		{
			project.technologies.map((tech) => (
				<span class="px-2.5 py-1 bg-secondary text-xs font-medium rounded-md text-secondary-content">
					{tech}
				</span>
			))
		}
	</div>
	<div class="flex space-x-3">
		<a
			href={project.githubUrl}
			target="_blank"
			rel="noopener noreferrer"
			class="flex items-center px-4 py-2 bg-primary/90 hover:bg-primary text-sm rounded-lg transition-colors text-base-100"
			aria-label={`View ${project.name} on GitHub (opens in new tab)`}
		>
			<Github size={16} class="mr-2" aria-hidden="true" />
			Github
		</a>
		{
			project.websiteUrl && (
				<a
					href={project.websiteUrl}
					target="_blank"
					rel="noopener noreferrer"
					class="flex items-center px-4 py-2 bg-primary/90 hover:bg-primary text-sm rounded-lg transition-colors text-base-100"
					aria-label={`Visit ${project.name} website (opens in new tab)`}
				>
					<Globe size={16} class="mr-2 " aria-hidden="true" />
					Website
				</a>
			)
		}
	</div>
</div>
