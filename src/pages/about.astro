---
import BaseLayout from "#/layouts/BaseLayout.astro"
import { getYearsAndMonths, getYOE } from "#/utils/dates"
import { Fragment } from "astro/dist/runtime/server"
---

<BaseLayout
	title="About - Simone Pizzamiglio"
	description="About Simone Pizzamiglio - Software Engineer"
>
	<div class="grid gap-16">
		<section>
			<h1 class="mb-8 text-5xl font-bold">About Me</h1>
			<div class="flex max-w-none flex-col leading-relaxed">
				<p>
					<b>Senior Software Engineer</b> with {getYOE(2016, 10)} years of experience
					experience building web products. I focus on creating modern web applications,
					with strong frontend expertise and experience contributing across the full
					stack.
				</p>
				<p>
					I’m a product-focused engineer who enjoys turning ideas into real
					products that people use. I care deeply about performance, user
					experience, and building systems that are simple, reliable, and easy
					to evolve over time.
				</p>
				<p>
					Over the years I’ve worked on B2B, B2C, and SaaS products across a
					variety of environments, ranging from large corporations to
					fast-growing startups, digital agencies, and freelance projects. These
					experiences taught me how to adapt quickly, work effectively in
					ambiguous situations, and collaborate closely with designers, product
					managers, and other engineers.
				</p>
				<p>
					While frontend is my main strength, I’m comfortable contributing
					across the stack and have also worked on areas like performance
					optimization, platform tooling, developer experience, and backend
					work.
				</p>
				<p>
					I’m always learning and exploring new technologies and approaches to
					build better products.
				</p>
			</div>
		</section>

		<section>
			<h2 class="mb-10 text-3xl font-bold">Skills</h2>
			<div class="flex flex-col gap-4">
				{
					[
						{
							group: "programming-languages",
							skills: ["Javascript", "TypeScript", "HTML", "CSS"],
						},
						{
							group: "technologies",
							skills: [
								"React",
								"Remix",
								"Next.js",
								"Redux",
								"React Query",
								"GraphQL",
								"Zod",
								"Tailwind CSS",
								"Styled-components",
								"MUI",
								"Storybook",
								"Cypress",
								"Playwright",
								"React-testing-library",
								"Jest",
								"Vitest",
								"Node.js",
								"Firebase",
								"Electron",
							],
						},
						{
							group: "cloud-platforms",
							skills: ["Google Cloud Platform"],
						},
						{ group: "databases", skills: ["Firestore"] },
					].map(({ group, skills }) => (
						<div>
							<h3 class="mb-2 font-semibold capitalize">
								{group.replace("-", " ")}
							</h3>
							<div class="flex flex-wrap gap-2">
								{skills.map((skill) => (
									<span class="badge bg-secondary rounded px-2 py-1 text-sm text-secondary-content">
										{skill}
									</span>
								))}
							</div>
						</div>
					))
				}
			</div>
		</section>

		<section>
			<h2 class="mb-10 text-3xl font-bold">Work Experience</h2>
			<div class="relative">
				<div class="bg-primary absolute bottom-0 left-0 top-2 w-px"></div>
				{
					[
						{
							company: "DNA.inc",
							companyUrl: "https://www.dna.inc/",
							location: "Amsterdam, Netherlands · Remote",
							startDate: "Nov 2024",
							endDate: null,
							roles: [
								{
									title: "Senior Web Engineer",
									achievements: [
										"Improved CI reliability and monorepo maintainability in a 50+ package NX workspace by deduplicating dependencies, enforcing package boundaries with custom ESLint rules, and automating dependency updates via Dependabot",
										"Led the monorepo-to-multi-repo split into domain-owned repositories and CI/CD pipelines, eliminating cross-team build coupling and unblocking parallel releases across product teams, improved release cadence and reduced coordination overhead",
										"Reduced SSR application JavaScript bundle size 30% by removing unused dependencies and optimizing code-splitting, improving first-load and hydration performance for uncached users",
										"Improved Core Web Vitals for a 3M monthly visits marketing site by eliminating layout shifts and optimizing asset loading and delivery, reducing homepage LCP from 1.9s to 1.1s (−42%), FCP from 1.15s to 950ms (−17%), TTFB from 461ms to 356ms (−23%), and driving CLS to ~0 on most pages",
									],
								},
							],
						},
						{
							company: "Bobsled",
							companyUrl: "https://bobsled.com/",
							location: "Anywhere · Remote",
							startDate: "Apr 2022",
							endDate: "Jul 2024",
							roles: [
								{
									title: "Senior Software Engineer",
									startDate: "Dec 2023",
									endDate: "Jul 2024",
									achievements: [
										"Designed a cross-platform data-type abstraction to standardize schema creation/querying across Snowflake, Databricks, BigQuery, and file formats (Parquet/CSV), reducing effort to add new integrations and preventing cross-warehouse schema drift",
										"Enhanced TypeScript support in the E2E repository, facilitating easier contributions from other engineers",
										"Owned end-to-end delivery for core API features (frontend + Node.js services), reducing cross-team handoffs and shortening time-to-ship for customer requests",
										"Served in on-call rotation after SRE training, triaging and resolving production incidents to meet reliability targets and reduce customer impact",
									],
								},
								{
									title: "Software Engineer",
									startDate: "Apr 2022",
									endDate: "Nov 2023",
									achievements: [
										"Architected and shipped an RBAC authorization layer to meet SOC 2 access-control requirements by modeling roles/permissions and enforcing checks across the API surface, reducing unauthorized access risk and audit findings",
										"Led architecture and development of a data grid component for displaying customer buckets and data warehouses",
										"Developed a caching and pagination system to handle large datasets efficiently, scaling to millions of objects",
										"Reduced large data-grid render time from seconds to milliseconds by introducing a snapshot-based rendering model and minimizing re-renders for large datasets",
										"Mentored junior engineers and participated in hiring assessments",
									],
								},
							],
						},
						{
							company: "Treatwell",
							companyUrl: "https://www.treatwell.co.uk/partners/",
							location: "Milan, Italy · Remote",
							startDate: "Apr 2020",
							endDate: "Mar 2022",
							roles: [
								{
									title: "Frontend Engineer",
									achievements: [
										"Improved Electron app startup (sign-in → first-page render) by 75% by profiling and optimizing critical-path data computation",
										"Refactored the printer integration layer to support multiple printer models through a flexible and extensible architecture, simplifying future integrations",
										"Built and evolved an internal design system (shared components, tokens, documentation) to standardize UI patterns and speed up feature development across teams",
										"Created an interactive dashboard from scratch to help beauty brands track partner performance metrics",
									],
								},
							],
						},
						{
							company: "ParkHere",
							companyUrl: "https://park-here.eu/",
							location: "Munich, Germany · Remote",
							startDate: "Apr 2019",
							endDate: "Mar 2020",
							roles: [
								{
									title: "Junior Frontend Engineer",
									achievements: [
										"Maintained and enhanced an analytics web app to enable companies to monitor parking metrics for their employees",
										"Developed a React-Native mobile application from the ground up to facilitate booking of parking slots",
									],
								},
							],
						},
						{
							company: "Self-Employed",
							companyUrl: null,
							location: "Udine, Italy",
							startDate: "Jul 2017",
							endDate: "Jun 2019",
							roles: [
								{
									title: "Web Developer",
									achievements: [
										"Delivered client websites for web agencies using WordPress/PHP, customizing themes/plugins",
										"Developed features for an e-commerce website built in Ruby on Rails and React",
									],
								},
							],
						},
						{
							company: "Freelancer.com",
							companyUrl: "https://www.freelancer.com/",
							location: "Sydney, Australia · On-site",
							startDate: "Nov 2016",
							endDate: "May 2017",
							roles: [
								{
									title: "Frontend Developer Intern",
									achievements: [
										"Revamped and A/B tested the job posting page with the Product Design Lead, increasing successful postings by 5%",
										"Standardized CSS architecture using SMACSS, improving maintainability and reducing style regressions for a multi-developer codebase",
										"Implemented responsive web design patterns to ensure compatibility across browsers, platforms, and devices",
									],
								},
							],
						},
					].map((company) => (
						<div class="relative pb-12 pl-8 last:pb-0">
							<div class="border-base-100 bg-primary absolute left-0 top-2 h-4 w-4 -translate-x-1/2 transform rounded-full border-4" />
							<div class="grid gap-6 md:grid-cols-3">
								<div class="md:col-span-1">
									<div class="mb-1 text-sm">
										{company.startDate} - {company.endDate || "Present"}
									</div>
									<div class=" mb-1 font-semibold">
										{company.companyUrl ? (
											<a
												href={company.companyUrl}
												class="underline"
												target="_blank"
											>
												{company.company}
											</a>
										) : (
											<span class="text-primary">{company.company}</span>
										)}
									</div>
									<div class="mb-1 text-sm">{company.location}</div>
								</div>

								<div class="space-y-6 md:col-span-2">
									{company.roles.map((role) => {
										const startDate = role.startDate || company.startDate
										const endDate = role.endDate || company.endDate
										const duration = getYearsAndMonths(startDate, endDate)
										return (
											<div>
												<div class="mb-3 flex items-center gap-2">
													<h3 class="mb-0 text-xl font-semibold">
														{role.title}
													</h3>
													<span class="text-sm">• {duration}</span>
												</div>
												<ul class="space-y-2">
													{role.achievements.map((achievement) => (
														<li class="flex items-start leading-relaxed">
															<span class="text-primary mr-3 shrink-0">•</span>
															{achievement}
														</li>
													))}
												</ul>
											</div>
										)
									})}
								</div>
							</div>
						</div>
					))
				}
			</div>
		</section>
	</div>
</BaseLayout>
